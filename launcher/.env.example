# PUMPTANK launcher env — copy to `launcher/.env` (gitignored) and fill in.
# There is no auto-loader yet, so load it before running, e.g.:
#   set -a; . ./.env; set +a; npm run launch -- --confirm
# (or export the vars in your shell). Ask if you'd like `.env` auto-loaded.

# --- required ---
# Helius RPC (business plan). The api-key lives ONLY here, never in the repo.
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
# House/deployer private key. Easiest: paste your base58 key from Phantom/Solflare
# ("Export Private Key"). A JSON byte array ([12,34,...]) from solana-keygen also works.
WALLET=your_base58_private_key_here
# Hard ceiling on dev-buy SOL spend (only the index token dev-buys):
MAX_TOTAL_SPEND_SOL=10

# --- optional (defaults shown) ---
SLIPPAGE_BPS=150          # 1.5%; hard cap 300
PRIORITY_FEE=200000       # microLamports
PACING_MS=1000            # sleep between launch waves
BATCH_SIZE=15             # create-only tributes per concurrent wave (pump.fun ceiling: 15)
MAX_RETRIES=2             # attempts per coin before it's marked failed
INDEX_DEV_BUY_SOL=3.5     # $PUMPTANK index dev-buy cap (index launch only)

# --- fees CLI only ---
MAIN_TOKEN_WALLET=        # $PUMPTANK fee-share payout pubkey (needed for set-shares)
MIN_COLLECT_SOL=0.005     # dust floor for `fees collect`
